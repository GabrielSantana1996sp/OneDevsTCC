    log "Cache encontrado em ${ARCHIVES_DIR} — build offline possível."
  else
    error "Cache de pacotes não encontrado. Rode o script uma vez com internet para criar o cache."
  fi
fi

run_build
log "Processo finalizado."
exit 0
