# Checagem de rede
ONLINE=0
check_network() {
  TEST_HOST="8.8.8.8"
  TEST_PORT=53
  TIMEOUT=3

  if ! ip route show default >/dev/null 2>&1; then
    ONLINE=0; return 0
  fi

  if bash -c "cat < /dev/null > /dev/tcp/${TEST_HOST}/${TEST_PORT}" >/dev/null 2>&1; then
    ONLINE=1; return 0
  fi

  if command -v ping >/dev/null 2>&1 && ping -c1 -W"$TIMEOUT" "$TEST_HOST" >/dev/null 2>&1; then
    ONLINE=1; return 0
  fi

  ONLINE=0
  return 0
}

check_network

if [ "${ONLINE}" -eq 1 ]; then
